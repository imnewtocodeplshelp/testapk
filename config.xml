<?xml version='1.0' encoding='utf-8'?>
<widget id="com.reflexsymphony.confetti" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>Reflex Symphony</name>
    <description>Reflex Symphony: Confetti Edition - A fast-paced tap game</description>
    <author email="dev@example.com" href="http://example.com">Dev</author>

    <content src="index.html" />

    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="33" />
    <preference name="Fullscreen" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="BackgroundColor" value="0xFF0f172a" />

    <platform name="android">
        <allow-intent href="market:*" />
    </platform>

</widget>
